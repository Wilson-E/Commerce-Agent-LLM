# Backend API base URL (e.g. https://your-app.onrender.com)
VITE_BACKEND_URL=https://your-app.onrender.com

# Backend WebSocket URL (e.g. wss://your-app.onrender.com)
VITE_WS_URL=wss://your-app.onrender.com

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Microsoft/Outlook OAuth Client ID
VITE_MICROSOFT_CLIENT_ID=your-microsoft-client-id
