# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# LLM Configuration
LLM_MODEL=gpt-4-turbo-preview
EMBEDDING_MODEL=text-embedding-3-small

# RapidAPI — Real-Time Product Search (https://rapidapi.com/letscrape-6bRBa3QguO5/api/real-time-product-search)
RAPIDAPI_KEY=your_rapidapi_key_here

# SerpAPI — Google Shopping (https://serpapi.com)
SERPAPI_KEY=your_serpapi_key_here

# Best Buy Products API (free — register at https://developer.bestbuy.com)
BEST_BUY_API_KEY=your_bestbuy_api_key_here

# Walmart Affiliate API (free — register at https://walmart.io)
WALMART_API_KEY=your_walmart_api_key_here

# Etsy Open API v3 (free — register at https://www.etsy.com/developers)
ETSY_API_KEY=your_etsy_api_key_here

# Open Food Facts — no key required; set to true to enable
OPENFOODFACTS_ENABLED=false

# Stripe (sandbox — get test keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Application
MAX_CONTEXT_TOKENS=8000
MAX_REACT_ITERATIONS=5
TAX_RATE=0.08
ENVIRONMENT=development
