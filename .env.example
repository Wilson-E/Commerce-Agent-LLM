# ──────────────────────────────────────────────────────────────
# Commerce-Agent-LLM — Environment Configuration
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Lines marked [REQUIRED] must be set or the server will not start.
# Lines marked [OPTIONAL] enable extra features but are not needed
# for the core demo.
# ──────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────

# [REQUIRED] OpenAI API key — powers the AI chat assistant
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# [REQUIRED] JWT signing secret — must be at least 32 random characters
# Generate one with:  python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE-ME-run-the-command-above

# ── LLM CONFIGURATION ───────────────────────────────────────

LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── OPTIONAL: Product Search APIs ────────────────────────────
# These enable live product search from real stores.
# The app works without them (uses built-in sample products).

# RapidAPI — Real-Time Product Search (https://rapidapi.com/letscrape-6bRBa3QguO5/api/real-time-product-search)
RAPIDAPI_KEY=

# SerpAPI — Google Shopping (https://serpapi.com)
SERPAPI_KEY=

# Rainforest API — Amazon product data (https://www.rainforestapi.com)
RAINFOREST_API_KEY=

# ScraperAPI — Amazon structured data (https://www.scraperapi.com)
SCRAPERAPI_KEY=

# Open Food Facts — no key required; set to true to enable
OPENFOODFACTS_ENABLED=false

# Category-specific APIs (both use RAPIDAPI_KEY — no new keys needed)
ASOS_ENABLED=false
HOMEDEPOT_ENABLED=false

# ── OPTIONAL: Stripe (Checkout) ─────────────────────────────
# Sandbox test keys from https://dashboard.stripe.com/test/apikeys
# Without these, checkout shows an order summary but skips payment.

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── OPTIONAL: OAuth Login ────────────────────────────────────
# Without these, users can still use guest mode.

GOOGLE_CLIENT_ID=
MICROSOFT_CLIENT_ID=

# ── OPTIONAL: Frontend / CORS ───────────────────────────────
# Only change if running frontend on a non-default origin.
# Default is http://localhost:3000 (matches Vite dev server).

FRONTEND_URL=http://localhost:3000
FRONTEND_URL_PATTERN=

# ── Application Tuning ──────────────────────────────────────

MAX_CONTEXT_TOKENS=8000
MAX_REACT_ITERATIONS=5
TAX_RATE=0.08
ENVIRONMENT=development
